APP_NAME=PTM Indonesia API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=9100
APP_READ_TIMEOUT_SECONDS=10
APP_WRITE_TIMEOUT_SECONDS=10
APP_IDLE_TIMEOUT_SECONDS=60
APP_SHUTDOWN_TIMEOUT_SECONDS=10
APP_TIMEZONE=Asia/Jakarta
APP_DEFAULT_LANGUAGE=id
APP_FALLBACK_LANGUAGE=en

DB_HOST=localhost
DB_HOST_DOCKER=db
DB_PORT=5432
DB_NAME=ptm_indonesia
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=25
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_HEALTH_CHECK_TIMEOUT_SECONDS=3

LOG_FILE_PATH=logs/app.log
LOG_LEVEL=error

MIGRATION_SOURCE=file://db/migrations

CORS_ORIGINS=http://localhost:3100,http://localhost:3101
COOKIE_SECRET=change_me
AUTH_COOKIE_NAME=ptm_auth_token
AUTH_REFRESH_COOKIE_NAME=ptm_refresh_token
AUTH_LOGGED_IN_COOKIE_NAME=logged_in
AUTH_ACCESS_TOKEN_TTL_MINUTES=15
AUTH_REFRESH_TOKEN_TTL_HOURS=8760
EMAIL_ADMIN=your_email@arzhi.com
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_MS=60000

GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:9100/api/v1/auth/google/callback
GOOGLE_ISSUER_URL=https://accounts.google.com
FRONTEND_URL=http://localhost:3101/home
BASEURL=http://localhost:9100
